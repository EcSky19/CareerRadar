# ── Copy this file to .env and fill in your values ───────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# ── Database (Supabase Transaction Pooler — port 6543) ────────────────────────
# IMPORTANT: prefix must be postgresql+asyncpg:// (not postgresql://)
# Get this from Supabase → Settings → Database → Transaction pooler URI
# then change the prefix from postgresql:// to postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres.your-project:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── Email alerts (Resend) ──────────────────────────────────────────────────────
RESEND_API_KEY=re_your_key_here
ALERT_FROM_EMAIL=alerts@yourdomain.com
ALERT_FROM_NAME=Career Radar

# ── Anthropic (Resume AI optimizer) ──────────────────────────────────────────
# Optional — leave blank to disable Resume AI feature
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production
